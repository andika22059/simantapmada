# =====================================================================
# .htaccess frontend SPA (Vue) — kompatibel Apache & LiteSpeed.
# 1) Semua rute yang bukan file/direktori nyata -> index.html (Vue Router).
#    Memakai pola "RewriteRule . /index.html" (BUKAN "^ index.html") karena
#    pola lama menyebabkan 403 Forbidden di LiteSpeed.
# 2) index.html tidak di-cache -> setelah deploy build baru, browser selalu
#    ambil index.html terbaru (mencegah halaman blank / "harus refresh").
#    File di /assets sudah ber-hash, jadi aman di-cache lama.
# =====================================================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # index.html diakses langsung -> layani apa adanya
  RewriteRule ^index\.html$ - [L]

  # Kalau BUKAN file & BUKAN direktori nyata -> arahkan ke index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # index.html: selalu ambil versi terbaru
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Aset ber-hash (JS/CSS/gambar/font): cache lama, aman karena nama berubah tiap build
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|woff2?|ttf|eot|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
