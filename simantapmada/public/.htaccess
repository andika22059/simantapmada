# =====================================================================
# .htaccess untuk frontend SPA (Vue) di web root mantapmada.com
# 1) Arahkan semua rute ke index.html (SPA routing).
# 2) index.html JANGAN di-cache → setelah deploy build baru, browser
#    selalu ambil index.html terbaru (mencegah halaman blank / "harus
#    refresh"). File di /assets sudah ber-hash, jadi aman di-cache lama.
# =====================================================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Jangan rewrite file/direktori yang benar-benar ada
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Sisanya diarahkan ke index.html (biar Vue Router yang menangani)
  RewriteRule ^ index.html [L]
</IfModule>

# ===== Aturan cache =====
<IfModule mod_headers.c>
  # index.html: selalu ambil versi terbaru
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Aset ber-hash (JS/CSS/gambar/font): cache lama, aman karena namanya berubah tiap build
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|woff2?|ttf|eot|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
